{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "git": {
    "deploymentEnabled": {
      "main": true,
      "features": true
    }
  },
  "functions": {
    "app/**/*.py": {
      "excludeFiles": "{tests/**,__tests__/**,**/*.test.py,**/test_*.py,fixtures/**,__fixtures__/**,testdata/**,sample-data/**,venv/**,.venv/**,logs/**,**/__pycache__/**}"
    }
  }
}
