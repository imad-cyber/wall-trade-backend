"""
Environment file template. Copy this to .env and fill in your values.
"""

# Application Configuration
APP_NAME=Wall-Trade-Backend
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Database Configuration (optional, if using additional database)
DATABASE_URL=postgresql://user:password@localhost/wall_trade

# Security Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Additional Services (Optional)
PSX_PROXY_URL=
PSX_PROXY_BASE_URL=
# Capital Stake (csapis.com) — UAT token for development; prod token for production.
# Base URL defaults to https://uat.csapis.com/3.0 (dev) or https://csapis.com/3.0 (prod).
CAPITAL_STAKE_BASE_URL=
CAPITAL_STAKE_UAT_TOKEN=
CAPITAL_STAKE_PROD_TOKEN=
CAPITAL_API_KEY=
CAPITAL_STAKE_API_KEY=
AI_API_KEY=
OPENAI_API_KEY=
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/api/v3

# AI Configuration
AI_MODEL=gpt-4o
AI_MAX_TOKENS=4096

# Cache TTL (hours)
ANALYSIS_CACHE_TTL_HOURS=24
MACRO_CACHE_TTL_HOURS=6

# HTTP Client Defaults
DEFAULT_TIMEOUT_SECONDS=10.0
DEFAULT_MAX_RETRIES=3

# CORS (alias — production example)
# ALLOWED_ORIGINS=["http://localhost:3000","https://wall-trade-v2.vercel.app"]
# CORS_ORIGIN_REGEX=https://.*-wall-trade-v2\.vercel\.app
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ORIGIN_REGEX=

# JWT validation notes:
# - Supabase issues ES256 (asymmetric) tokens by default — backend validates via JWKS
#   at {SUPABASE_URL}/auth/v1/.well-known/jwks.json (no SUPABASE_JWT_SECRET required).
# - Legacy HS256 tokens still supported when SUPABASE_JWT_SECRET is set.
# - SUPABASE_URL must match the frontend NEXT_PUBLIC_SUPABASE_URL project.
