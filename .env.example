"""
Environment file template. Copy this to .env and fill in your values.
"""

# Application Configuration
APP_NAME=Wall-Trade-Backend
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Database Configuration (optional, if using additional database)
DATABASE_URL=postgresql://user:password@localhost/wall_trade

# Security Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Additional Services (Optional)
PSX_PROXY_URL=
CAPITAL_API_KEY=
CAPITAL_STAKE_API_KEY=
AI_API_KEY=
FMP_API_KEY=
